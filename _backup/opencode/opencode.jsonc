{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "experimental": {
    "disable_paste_summary": true
  },
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "opentmux@latest",
    "opencode-mystatus@latest",
    "./plugin/protect-sensitive-files.js"
  ],
  "command": {
    "quotas": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification, ONLY for GitHub Copilot. If there are any errors, suppress them."
    }
  }
}
