{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "experimental": {
    "disable_paste_summary": true
  },
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "plugin": [
    // "@plannotator/opencode@latest",
    "oh-my-opencode",
    "./plugin/protect-sensitive-files.js",
    "opencode-mystatus"
  ],
  "command": {
    "quotas": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification, ONLY for GitHub Copilot. If there are any errors, suppress them.",
    },
    "copilot-feedback": {
      "template": "Copilot reviewed the PR and generated comments. Please review only the unresolved comments and make any suggestions necessary (and only when it makes sense). Be critical about it and think hard if you need to change anything. If you have any doubts, ask me questions in interview-style). After that, reply to Copilot's comments.",
      "description": "Consult Copilot PR review and apply edits when necessary. ONLY for GitHub Copilot.",
      "agent": "sisyphus",
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "thinking"
    }
  }
}
