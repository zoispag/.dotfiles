{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-wakatime@latest",
    "./plugin/protect-sensitive-files.js"
  ],
  "experimental": {
    "disable_paste_summary": true
  },
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "compaction": {
      "model": "github-copilot/claude-sonnet-4.6"
    }
  },
  "mcp": {
    "vanta": {
      "type": "remote",
      "url": "https://mcp.eu.vanta.com/mcp"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "grafana_cloud": {
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_CLOUD_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_CLOUD_SERVICE_ACCOUNT_TOKEN}"
      }
    },
    "grafana_k8s": {
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_K8S_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_K8S_SERVICE_ACCOUNT_TOKEN}"
      }
    },
    "argocd": {
      "type": "local",
      "command": ["npx", "argocd-mcp@latest", "stdio"],
      "environment": {
	      "ARGOCD_BASE_URL": "{env:ARGOCD_BASE_URL}",
	      "ARGOCD_API_TOKEN": "{env:ARGOCD_API_TOKEN}"
      }
    },
    "slack": {
      "type": "local",
      "command": ["npx", "-y", "slack-mcp-server@latest", "--transport", "stdio"],
      "environment": {
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_XOXP_TOKEN}"
      }
    }
  }
}
